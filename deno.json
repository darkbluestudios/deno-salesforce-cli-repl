{
  "name": "@darkbluestudios/salesforce-cli-repl",
  "version": "0.11.0",
  "license": "MIT",

  "nodeModulesDir": "auto",
  
  "exports": {
    ".": "./src/main.ts",
    "./DeveloperError": "./src/DeveloperError.ts"
  },
  "tasks": {
    "doc": "deno doc --html --output='./docs' -r src",
    "test": "deno test --allow-env --allow-read",
    "test:watch": "deno test --watch --allow-env --allow-read",
    "lint": "deno lint src tests",
    "lint:watch": "deno lint --watch src tests",
    "coverage:generate": "deno test --coverage=cov_profile --allow-read --allow-env",
    "coverage:report": {
      "command": "deno coverage --lcov --output=cov.lcov cov_profile/",
      "dependencies": [ "coverage:generate"]
    },
    "coverage:html": {
      "command": "genhtml -o html_cov --ignore-errors inconsistent cov.lcov",
      "dependencies": [ "coverage:report"]
    },
    "coverage:open-only": "open html_cov/index.html",
    "coverage:open": {
      "command": "deno run coverage:open-only",
      "dependencies": [ "coverage:html"]
    },
    "coverage": {
      "command": "echo 'Complete'",
      "dependencies": [
        "coverage:open"
      ]
    },
    "build": {
      "command": "deno publish --dry-run",
      "dependencies": [
        "lint",
        "coverage:html"
      ]
    },
    "prepare": {
      "command": "deno publish --dry-run"
    }
  },
  "test": {
  	"include": ["tests/**/*__spec.ts"]
  },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@0.225.6",
    "@std/assert": "jsr:@std/assert@1",
    "@std/expect": "jsr:@std/expect@^1.0.17",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "jsforce": "npm:jsforce@3.10.14"
  },
  "lint": {
    "rules": {
      "exclude": ["no-unversioned-import", "no-prototype-builtins"]
    }
  },
  "allowScripts": ["npm:core-js-pure@3.48.0", "npm:core-js@3.48.0"]
}
