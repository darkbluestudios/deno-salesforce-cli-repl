#!/bin/bash

# sets the current window's name
# screen -X sessionname "denoUtils"
screen -X title "root"
screen -X number 0

screen -t lint
sleep 1
screen -p lint -X stuff "deno run lint:watch"
#sleep 1
screen -t test
sleep 1
screen -p test -X stuff "deno run test:watch"
#sleep 1
screen -t debug
sleep 1


screen -t "server" 10
sleep 1
screen -p server -X number 10
#sleep 1
screen -p server -X stuff "cd ../^Mjupyter lab"
sleep 1

screen -X select 0
#sleep 1

# create layouts

screen -X layout new default
#sleep 1
screen -X select base
#sleep 1

screen -X layout new test
sleep 1
screen -X select test
#sleep 1
screen -X split -h
#sleep 1
screen -X resize 60%
#sleep 1
screen -X focus
#sleep 1
screen -X select lint
#sleep 1

screen -X layout new server
sleep 1
screen -X select server
#sleep 1

screen -X layout select default
sleep 1

# key bindings

# screen -X bindkey -k k1 layout select 0
# screen -X bindkey -k k2 layout select 1
# screen -X bindkey -k k3 layout select 2

# sets a screen session for the current project
screen -X sessionname salesforce-cli-repl
